{
  "name": "slimsearch",
  "version": "2.3.0",
  "description": "Tiny but powerful full-text search engine for browser and Node",
  "keywords": [
    "auto complete",
    "auto suggest",
    "full text",
    "fuzzy",
    "index",
    "prefix",
    "search"
  ],
  "homepage": "https://mister-hope.github.io/slimsearch/",
  "bugs": "https://github.com/Mister-Hope/slimsearch/issues",
  "license": "MIT",
  "author": "Luca Ongaro, Mister Hope",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mister-Hope/slimsearch.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./SearchableMap": {
      "types": "./dist/SearchableMap.d.ts",
      "default": "./dist/SearchableMap.js"
    }
  },
  "scripts": {
    "benchmark": "vitest bench",
    "benchmark:build": "BENCHMARK=true pnpm run build",
    "benchmark:legacy": "pnpm run benchmark:build && NODE_ENV=production node --expose-gc benchmarks/dist/index.cjs",
    "build": "tsdown",
    "bundle:analyze": "node --experimental-strip-types scripts/analyze.ts",
    "clean": "rimraf dist",
    "dev": "tsdown -w",
    "docs:build": "typedoc --options typedoc.json",
    "lint": "oxlint --fix --report-unused-disable-directives --deny-warnings && oxfmt",
    "lint:check": "oxlint --report-unused-disable-directives --deny-warnings && oxfmt --check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest --coverage"
  },
  "devDependencies": {
    "@codecov/bundle-analyzer": "2.0.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@mr-hope/tsconfig": "0.0.4",
    "@types/benchmark": "2.1.5",
    "@types/node": "22.20.0",
    "@vitest/coverage-istanbul": "4.1.9",
    "benchmark": "2.1.4",
    "fast-check": "4.8.0",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.3",
    "tslib": "2.8.1",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --report-unused-disable-directives --deny-warnings"
  },
  "commitlint": {
    "extends": "@commitlint/config-conventional"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^22.22.0 || ^24.16.0 || ^26.3.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
